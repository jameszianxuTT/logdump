 @pytest.mark.parametrize("layout", [ttnn.TILE_LAYOUT])
    def test_double_nested_where_minimal(self, device, layout):
        """
        Minimal reproduction: Two sequential nested where operations.

        This isolates the interaction between two where operations with
        broadcasting masks of different shapes.
        """
        torch.manual_seed(42)

        # Step 1: Update x using column mask
        x = torch.randn(1, 4, 32, dtype=torch.bfloat16)
        col_mask = torch.zeros(1, 1, 32, dtype=torch.bfloat16)
        col_mask[:, :, 16:] = 1.0
        new_x_vals = x.clone()
        new_x_vals[:, :, 16:] = x[:, :, 16:] * 2.0

        # Step 2: Update cache using row mask
        cache = torch.zeros(1, 8, 32, dtype=torch.bfloat16)
        row_mask = torch.zeros(1, 8, 1, dtype=torch.bfloat16)
        row_mask[:, :4, :] = 1.0

        # === PyTorch reference ===
        x_updated = torch.where(col_mask.bool().expand_as(x), new_x_vals, x)
        x_expanded = torch.zeros(1, 8, 32, dtype=torch.bfloat16)
        x_expanded[:, :4, :] = x_updated
        cache_expected = torch.where(row_mask.bool().expand_as(cache), x_expanded, cache)

        # === TTNN with nested where ===
        x_ttnn = ttnn.from_torch(x, device=device, layout=layout, dtype=ttnn.bfloat16)
        new_x_vals_ttnn = ttnn.from_torch(new_x_vals, device=device, layout=layout, dtype=ttnn.bfloat16)
        cache_ttnn = ttnn.from_torch(cache, device=device, layout=layout, dtype=ttnn.bfloat16)

        col_mask_ttnn = ttnn.from_torch(col_mask, device=device, layout=layout, dtype=ttnn.bfloat16)
        row_mask_ttnn = ttnn.from_torch(row_mask, device=device, layout=layout, dtype=ttnn.bfloat16)
        zero_ttnn = ttnn.from_torch(torch.zeros(1, 1, 1, dtype=torch.bfloat16), device=device, layout=layout, dtype=ttnn.bfloat16)

        not_col_mask = ttnn.logical_not(col_mask_ttnn)
        not_row_mask = ttnn.logical_not(row_mask_ttnn)

        # First nested where: update x
        temp1 = ttnn.where(not_col_mask, zero_ttnn, new_x_vals_ttnn)
        x_updated_ttnn = ttnn.where(col_mask_ttnn, temp1, x_ttnn)

        # Expand x to cache shape
        x_upd = ttnn.to_torch(x_updated_ttnn)
        x_expanded_torch = torch.zeros(1, 8, 32, dtype=torch.bfloat16)
        x_expanded_torch[:, :4, :] = x_upd
        x_expanded_ttnn = ttnn.from_torch(x_expanded_torch, device=device, layout=layout, dtype=ttnn.bfloat16)

        # Second nested where: update cache
        temp2 = ttnn.where(not_row_mask, zero_ttnn, x_expanded_ttnn)
        cache_updated = ttnn.where(row_mask_ttnn, temp2, cache_ttnn)
        cache_result = ttnn.to_torch(cache_updated)

        log_finding("\n[test_double_nested_where_minimal]")
        log_finding(f"Expected cache[0,0,:8]: {cache_expected[0, 0, :8].tolist()}")
        log_finding(f"Actual cache[0,0,:8]: {cache_result[0, 0, :8].tolist()}")
        log_finding(f"Non-zero in actual: {(cache_result[:1, :4] != 0).sum().item()}")
        log_finding(f"Non-zero in expected: {(cache_expected[:1, :4] != 0).sum().item()}")

        first_col_nonzero = (cache_result[:1, :4, 0] != 0).sum().item()
        other_cols_nonzero = (cache_result[:1, :4, 1:] != 0).sum().item()
        log_finding(f"First col non-zero: {first_col_nonzero}, Other cols: {other_cols_nonzero}")

        if other_cols_nonzero == 0 and first_col_nonzero > 0:
            log_finding("BUG REPRODUCED in minimal test!")

        assert_with_pcc(cache_expected, cache_result, 0.9999)



