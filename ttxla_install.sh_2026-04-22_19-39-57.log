#!/bin/bash
# usage: curl -sSL https://your-server.com/install.sh | bash
# curl -sSL https://your-server.com/install.sh | bash -s -- feature-alpha

run_install() {
    set -eo pipefail

    local branch_or_commit="${1:-main}"
    local repo_url="https://github.com/tenstorrent/tt-xla.git"
    local dir_name="tt-xla"

    # 1. Early Exit if directory exists
    if [ -d "$dir_name" ]; then
        echo "Exiting: Directory '$dir_name' already exists. Please remove it to re-install."
        exit 1
    fi

    echo "--- Initializing tt-xla build ($branch_or_commit) ---"

    # 2. Clone via HTTPS
    echo "Cloning repository..."
    git clone --recursive "$repo_url" "$dir_name"
    cd "$dir_name"

    # 3. Checkout target ref
    echo "Checking out $branch_or_commit..."
    git checkout "$branch_or_commit"

    # 4. Environment Activation
    if [ -f "venv/activate" ]; then
        echo "Activating internal venv..."
        # Some callers may invoke bash with inherited nounset (-u). Temporarily
        # disable it around activation so environment scripts that expect unset
        # vars do not fail.
        local had_nounset=0
        case $- in
            *u*) had_nounset=1; set +u ;;
        esac
        source venv/activate
        if [ "$had_nounset" -eq 1 ]; then
            set -u
        fi
    else
        echo "Error: Expected venv/activate not found in repository."
        exit 1
    fi

    # 5. Build
    echo "Starting bldxla Debug..."
        check_return_code() {
        if [ $? -ne 0 ]; then
            echo "Error: $1 failed. Exiting."
	    exit 1
        fi
    }

    # Run cmake commands
    cmake -G Ninja -B build -DCMAKE_BUILD_TYPE=Release
    check_return_code "cmake configuration"

    cmake --build build
    check_return_code "cmake build"

    echo "Build and installation of tt-xla completed successfully."

    echo "--------------------------------------------------------"
    echo "✅ Success: tt-xla build from $branch_or_commit complete."
    echo "--------------------------------------------------------"
}

# The wrapper ensures the script is fully downloaded before execution
run_install "$@"
